&НаСервере
Процедура ВКМ_УправлениеВидимостью()
	
	// 1. Проверяем, является ли договор Абонентским
	ЭтоАбонентский = (Объект.ВидДоговора = Перечисления.ВКМ_ВидыДоговоров.Абонентский);
	
	// 2. Логика для Абонентского договора:
	// Показываем Абонентскую плату, СКРЫВАЕМ Стоимость часа
	Элементы.АбонентскаяПлата.Видимость = ЭтоАбонентский;
	
	// 3. Логика для Разового договора:
	// Скрываем Абонентскую плату, ПОКАЗЫВАЕМ Стоимость часа
	// Для этого используем частицу "НЕ" (инверсия)
	Элементы.СтоимостьЧаса.Видимость = НЕ ЭтоАбонентский;
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Это нужно, чтобы при открытии уже созданного договора поле тоже скрывалось
	ВКМ_УправлениеВидимостью();
КонецПроцедуры

&НаКлиенте
Процедура ВидДоговораПриИзменении(Элемент)
	// Это срабатывает, когда ты кликаешь мышкой в форме
	ВКМ_УправлениеВидимостью();
КонецПроцедуры