#Область ПрограммныйИнтерфейс

// Записывает факт изменения статуса заявки в регистр "ИсторияСтатусовЗаявок".
//
// Параметры:
//  СсылкаНаОбъект - ДокументСсылка.BKM_Заявка - Заявка, для которой записывается история.
//  НовыйСтатус    - ПеречислениеСсылка.BKM_СтатусыЗаявок - Новый статус заявки.
//  Ответственный  - СправочникСсылка.Пользователи - Ответственный за изменение.
//  Комментарий    - Строка - Комментарий к изменению статуса.
//
Процедура ВКМ_ЗаписатьИсториюСтатуса(СсылкаНаОбъект, НовыйСтатус, Ответственный, Комментарий) Экспорт

	Набор = РегистрыСведений.ИсторияСтатусовЗаявок.СоздатьНаборЗаписей();

	Запись = Набор.Добавить();
	Запись.Период        = ТекущаяДатаСеанса();
	Запись.Заявка        = СсылкаНаОбъект;
	Запись.Статус        = НовыйСтатус;
	Запись.Ответственный = Ответственный;
	Запись.Комментарий   = Комментарий;

	Набор.Записать(Истина);

КонецПроцедуры

#КонецОбласти
