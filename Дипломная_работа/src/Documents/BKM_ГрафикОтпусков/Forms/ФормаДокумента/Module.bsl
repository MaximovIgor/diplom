#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	BKM_ПересчитатьИПодсветить();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура BKM_ПересчитатьИПодсветить()

	Для каждого Стр Из Объект.BKM_ОтпускаСотрудников Цикл

		Если Стр.BKM_ДатаНачала = Неопределено Или Стр.BKM_ДатаОкончания = Неопределено Тогда
			Стр.BKM_Дней = 0;
			Продолжить;
		КонецЕсли;

		// Нормализуем до начала дня, чтобы не влияли часы/минуты
		ДатаНач = НачалоДня(Стр.BKM_ДатаНачала);
		ДатаКон = НачалоДня(Стр.BKM_ДатаОкончания);

		// Разница дат в 1С — это число секунд
		РазницаСек = ДатаКон - ДатаНач;

		// Переводим в дни и делаем включительно (+1)
		Дней = Цел(РазницаСек / 86400) + 1;

		Если Дней < 0 Тогда
			Дней = 0;
		КонецЕсли;

		Стр.BKM_Дней = Дней;

	КонецЦикла;

КонецПроцедуры

#КонецОбласти
