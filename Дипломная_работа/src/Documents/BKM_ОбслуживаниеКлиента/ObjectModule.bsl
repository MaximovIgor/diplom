#Область ОбработчикиСобытий

// НОВОЕ: Процедура для выполнения первого замечания (сравнение с БД)
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	// Если документ новый — сравнивать не с чем, выходим
	Если ЭтоНовый() Или ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	// 1. Получаем текущие (старые) значения из базы данных ЗАПРОСОМ
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Док.BKM_Специалист КАК Специалист,
		|	Док.BKM_Договор КАК Договор
		|ИЗ
		|	Документ.ОбслуживаниеКлиента КАК Док
		|ГДЕ
		|	Док.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		// 2. Сравниваем значения в памяти (ЭтотОбъект) со значениями из БД (Выборка)
		Если Выборка.Специалист <> BKM_Специалист Тогда
			// Здесь можно добавить логику, если специалист изменился
			// Например: Сообщить("Специалист был изменен!");
		КонецЕсли;
		
		Если Выборка.Договор <> BKM_Договор Тогда
			// Логика при изменении договора
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Если BKM_Специалист = Неопределено Тогда
		ВызватьИсключение "Не указан специалист.";
	КонецЕсли;

	Если BKM_Договор = Неопределено Тогда
		ВызватьИсключение "Не указан договор.";
	КонецЕсли;

	Процент = ПолучитьПроцентОплаты(НачалоМесяца(Дата), BKM_Специалист);

	Если Процент = Неопределено Или Процент <= 0 Тогда
		ВызватьИсключение "Не установлены условия оплаты (процент от работ) на месяц документа.";
	КонецЕсли;

	ЧасыКОплатеКлиенту = 0;
	Для каждого Стр Из BKM_ВыполненныеРаботы Цикл
		ЧасыКОплатеКлиенту = ЧасыКОплатеКлиенту + Стр.BKM_ЧасыКОплате;
	КонецЦикла;

	// Используем обновленную функцию
	СтавкаЧасаКлиента = ПолучитьСтоимостьЧасаДоговора(BKM_Договор);

	Если СтавкаЧасаКлиента = Неопределено Или СтавкаЧасаКлиента <= 0 Тогда
		ВызватьИсключение "В договоре не указана стоимость часа.";
	КонецЕсли;

	СуммаКОплатеСотруднику = Окр(ЧасыКОплатеКлиенту * СтавкаЧасаКлиента * Процент / 100, 2);

	Движения.BKM_ВыполненныеСотрудникомРаботы.Записывать = Истина;
	Движение = Движения.BKM_ВыполненныеСотрудникомРаботы.Добавить();
	Движение.Период = Дата;
	Движение.BKM_Сотрудник = BKM_Специалист;
	Движение.BKM_ЧасовКОплате = ЧасыКОплатеКлиенту;
	Движение.BKM_СуммаКОплате = СуммаКОплатеСотруднику;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьПроцентОплаты(Период, Сотрудник) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Условия.BKM_ПроцентОтРабот КАК Процент
	|ИЗ
	|	РегистрСведений.BKM_УсловияОплатыСотрудников КАК Условия
	|ГДЕ
	|	Условия.BKM_Сотрудник = &Сотрудник
	|	И Условия.Период <= &Период
	|УПОРЯДОЧИТЬ ПО
	|	Условия.Период УБЫВ";

	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("Период", Период);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Процент;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Функция ПолучитьСтоимостьЧасаДоговора(ДоговорСсылка) Экспорт

	// ИСПРАВЛЕНО: Теперь используется имя нового справочника ДоговорыКонтрагентов
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Договор.СтоимостьЧаса КАК СтоимостьЧаса
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК Договор
	|ГДЕ
	|	Договор.Ссылка = &Ссылка";

	Запрос.УстановитьПараметр("Ссылка", ДоговорСсылка);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.СтоимостьЧаса;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

#КонецОбласти