// Файл: Конфигурация/src/Documents/ВКМ_НачислениеУпрЗП/ObjectModule.bsl

#Область ОписаниеПеременных

// В модуле объекта доступ к табличной части осуществляется через ЭтотОбъект
// Перем BKM_Начисления; 

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)

	// обязательная проверка для обменов/загрузки
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	// Соберем список сотрудников из табличной части
	Сотрудники = Новый Массив;
	Для каждого Стр Из ЭтотОбъект.BKM_Начисления Цикл
		Если Стр.BKM_Сотрудник <> Неопределено Тогда
			Сотрудники.Добавить(Стр.BKM_Сотрудник);
		КонецЕсли;
	КонецЦикла;

	// Получим ставки одним запросом (последняя по периоду)
	СтавкиПоСотрудникам = BKM_ПолучитьСтавкиПоСотрудникам(Сотрудники);

	// Расчет сумм
	Для каждого Стр Из ЭтотОбъект.BKM_Начисления Цикл

		Если Стр.BKM_Ставка = 0 Тогда
			Если Стр.BKM_Сотрудник <> Неопределено
				И СтавкиПоСотрудникам.СодержитКлюч(Стр.BKM_Сотрудник) Тогда

				Стр.BKM_Ставка = СтавкиПоСотрудникам[Стр.BKM_Сотрудник];

			Иначе
				Стр.BKM_Ставка = 0;
			КонецЕсли;
		КонецЕсли;

		Стр.BKM_Сумма = Окр(Стр.BKM_Часы * Стр.BKM_Ставка, 2);

	КонецЦикла;

КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Функция BKM_ПолучитьСтавкиПоСотрудникам(СотрудникиМассив) Экспорт

	Результат = Новый Соответствие;

	Если СотрудникиМассив = Неопределено Или СотрудникиМассив.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	// 1) Найдем последний период по каждому сотруднику
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Ставки.BKM_Сотрудник КАК Сотрудник,
	|	МАКСИМУМ(Ставки.Период) КАК Период
	|ИЗ
	|	РегистрСведений.BKM_СтавкиСотрудников КАК Ставки
	|ГДЕ
	|	Ставки.BKM_Сотрудник В (&Сотрудники)
	|СГРУППИРОВАТЬ ПО
	|	Ставки.BKM_Сотрудник";

	Запрос.УстановитьПараметр("Сотрудники", СотрудникиМассив);

	ТабПериодов = Запрос.Выполнить().Выгрузить();
	Если ТабПериодов.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	// 2) По найденным периодам получим ставку
	Запрос2 = Новый Запрос;
	Запрос2.Текст =
	"ВЫБРАТЬ
	|	Ставки.BKM_Сотрудник КАК Сотрудник,
	|	Ставки.BKM_Ставка КАК Ставка
	|ИЗ
	|	РегистрСведений.BKM_СтавкиСотрудников КАК Ставки
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ &ТабПериодов КАК П
	|	ПО Ставки.BKM_Сотрудник = П.Сотрудник
	|	И Ставки.Период = П.Период";

	Запрос2.УстановитьПараметр("ТабПериодов", ТабПериодов);

	Выборка = Запрос2.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Сотрудник, Выборка.Ставка);
	КонецЦикла;

	Возврат Результат;

КонецФункции

#КонецОбласти
